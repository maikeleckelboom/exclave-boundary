{
  "name": "exclave-boundary",
  "type": "module",
  "version": "0.0.0",
  "private": true,
  "description": "typed shared-memory boundary substrate for coherent state, deterministic layout, explicit handoff, and timing-sensitive runtimes.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/maikeleckelboom/exclave-boundary.git"
  },
  "homepage": "https://github.com/maikeleckelboom/exclave-boundary#readme",
  "bugs": {
    "url": "https://github.com/maikeleckelboom/exclave-boundary/issues"
  },
  "devDependencies": {
    "@commitlint/cli": "catalog:",
    "@commitlint/config-conventional": "catalog:",
    "@commitlint/types": "catalog:",
    "@vitest/coverage-v8": "catalog:",
    "eslint": "catalog:",
    "eslint-import-resolver-typescript": "catalog:",
    "eslint-plugin-import": "catalog:",
    "fast-check": "catalog:",
    "markdownlint-cli2": "catalog:",
    "prettier": "catalog:",
    "rimraf": "catalog:",
    "simple-git-hooks": "catalog:",
    "typescript": "catalog:",
    "typescript-eslint": "catalog:",
    "vite": "catalog:",
    "vitest": "catalog:"
  },
  "scripts": {
    "prepare": "simple-git-hooks",
    "clean:artifacts": "pnpm -r -F \"@exclave/boundary\" -F \"@exclave/docs\" run clean && rimraf .eslintcache node_modules/.vite node_modules/.cache pnpm-debug.log",
    "clean:workspace": "pnpm run clean:artifacts",
    "clean:dry": "git clean -xfdn -e .env -e \".env.*\"",
    "clean": "git clean -xfd -e .env -e \".env.*\"",
    "clean:cache": "rimraf node_modules/.vite node_modules/.cache packages/*/node_modules/.vite packages/*/node_modules/.cache apps/*/node_modules/.vite apps/*/node_modules/.cache",
    "clean:caches": "pnpm run clean:cache",
    "purge": "pnpm run clean",
    "build": "pnpm -w run clean:artifacts && pnpm -r -F \"@exclave/boundary\" run build",
    "test": "pnpm -w -F \"@exclave/boundary\" run test",
    "bench": "pnpm -w -F \"@exclave/boundary\" run bench",
    "bench:report": "pnpm -w -F \"@exclave/boundary\" run bench:report",
    "test:types": "pnpm -w -F \"@exclave/boundary\" run test:types",
    "test:watch": "pnpm run test --watch",
    "test:cov": "pnpm -w -F \"@exclave/boundary\" run test:cov",
    "test:pack": "pnpm -w -F \"@exclave/boundary\" run test:pack",
    "commitlint": "commitlint --color",
    "lint:md": "markdownlint-cli2",
    "lint:md:fix": "markdownlint-cli2 --fix",
    "lint": "pnpm -r -F \"@exclave/boundary\" -F \"@exclave/docs\" run lint",
    "lint:fix": "pnpm -r -F \"@exclave/boundary\" -F \"@exclave/docs\" run lint:fix",
    "lint:all": "pnpm lint && pnpm lint:md",
    "format": "prettier --ignore-path .prettierignore --write .",
    "docs": "pnpm docs:build",
    "docs:dev": "pnpm -F @exclave/docs run docs:dev",
    "docs:build": "pnpm -F @exclave/docs run docs:build",
    "docs:preview": "pnpm -F @exclave/docs run docs:preview",
    "signalsmith:dev": "pnpm --filter \"@exclave/signalsmith-stretch\" run dev",
    "signalsmith:build": "pnpm --filter \"@exclave/signalsmith-stretch\" run build",
    "signalsmith:build:real": "pnpm --filter \"@exclave/signalsmith-stretch\" run build:real",
    "signalsmith:check": "pnpm --filter \"@exclave/signalsmith-stretch\" run check",
    "signalsmith:test:browser": "pnpm --filter \"@exclave/signalsmith-stretch\" run test:browser",
    "signalsmith:prepare": "pnpm --filter \"@exclave/signalsmith-stretch\" run prepare:real",
    "signalsmith:build:wasm": "pnpm --filter \"@exclave/signalsmith-stretch\" run build:wasm",
    "signalsmith:test:browser:real": "pnpm --filter \"@exclave/signalsmith-stretch\" run test:browser:real",
    "check:diff-whitespace": "git diff --check origin/main...HEAD",
    "support": "node scripts/support/boundary-support.ts",
    "fresh": "pnpm clean && pnpm install --frozen-lockfile && pnpm build && pnpm signalsmith:build && pnpm signalsmith:build:real",
    "verify": "pnpm clean:artifacts && pnpm build && pnpm lint && pnpm test:types && pnpm test && pnpm signalsmith:check && pnpm run docs && pnpm test:pack && pnpm support --json",
    "verify:fresh": "pnpm fresh && pnpm lint && pnpm test:types && pnpm test && pnpm signalsmith:check && pnpm run docs && pnpm test:pack && pnpm support --json && pnpm signalsmith:test:browser && pnpm signalsmith:test:browser:real"
  },
  "simple-git-hooks": {
    "commit-msg": "pnpm commitlint --edit $1"
  },
  "packageManager": "pnpm@11.6.0"
}
